# API Configuration
VITE_API_URL=http://localhost:3000/api

# Gateway Configuration (WebSocket)
VITE_GATEWAY_URL=ws://localhost:3002/gateway

# Keycloak Configuration
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=teamcord
VITE_KEYCLOAK_CLIENT_ID=teamcord-web

# Voice Configuration
VITE_VOICE_URL=http://localhost:3003
VITE_VOICE_SOCKET_PATH=/voice/socket.io

# Error Monitoring (Optional)
# Set this to enable Sentry error tracking in production
# Get your DSN from https://sentry.io
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
