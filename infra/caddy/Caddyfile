# TeamCord Caddyfile
# Auto-TLS reverse proxy configuration

# Development (localhost)
{$DOMAIN:localhost} {
  # Files API routes -> files service (strip /api/v1/files prefix)
  handle_path /api/v1/files/* {
    reverse_proxy files:3003
  }

  # API endpoints
  handle /api/* {
    reverse_proxy messaging:3001
  }
  
  # WebSocket Gateway
  @websocket {
    path /gateway
    header Connection *Upgrade*
    header Upgrade websocket
  }
  handle @websocket {
    reverse_proxy gateway:3002
  }
  
  # Voice signaling (socket.io long-poll + websocket upgrade)
  @voiceWebsocket {
    path /voice/*
    header Connection *Upgrade*
    header Upgrade websocket
  }
  handle @voiceWebsocket {
    reverse_proxy voice:3004
  }
  handle /voice/* {
    reverse_proxy voice:3004
  }

  # Files service signed URL handoff
  handle /f/* {
    reverse_proxy files:3003
  }
  
  # MinIO (S3) - presigned URLs
  handle /files/* {
    reverse_proxy minio:9000
  }
  
  # Swagger docs
  handle /docs* {
    reverse_proxy messaging:3001
  }
  
  # Web frontend (catch-all)
  handle {
    reverse_proxy web:3000
  }
  
  # Security headers
  header {
    X-Content-Type-Options nosniff
    X-Frame-Options DENY
    X-XSS-Protection "1; mode=block"
    Referrer-Policy strict-origin-when-cross-origin
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    -Server
  }
  
  # Compression
  encode gzip zstd
  
  # TLS (auto-configured for production domains)
  # For localhost, Caddy will use a local CA
  tls {$ADMIN_EMAIL:internal}
  
  # Logging
  log {
    output file /var/log/caddy/access.log {
      roll_size 100mb
      roll_keep 5
    }
    format json
  }
}

# Health check endpoint
:8080 {
  respond /health "OK" 200
}
