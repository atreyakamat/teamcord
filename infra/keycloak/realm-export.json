{
  "realm": "teamcord",
  "enabled": true,
  "displayName": "TeamCord",
  "clients": [
    {
      "clientId": "teamcord-web",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:3000/app",
        "http://localhost:3000/app/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": ["http://localhost:3000"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/*"
      }
    },
    {
      "clientId": "teamcord-api",
      "enabled": true,
      "bearerOnly": false,
      "publicClient": false,
      "secret": "teamcord-api-secret-change-me",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "TeamCord Administrator"
      },
      {
        "name": "user",
        "description": "TeamCord Regular User"
      }
    ]
  },
  "users": [
    {
      "username": "admin",
      "email": "admin@teamcord.sh",
      "enabled": true,
      "firstName": "TeamCord",
      "lastName": "Admin",
      "realmRoles": ["admin"],
      "credentials": [
        {
          "type": "password",
          "value": "nexus_admin_pass",
          "temporary": false
        }
      ]
    }
  ]
}
