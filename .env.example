# ─── Teamcord Environment Variables ───────────────────────────────────────

# PostgreSQL
POSTGRES_DB=teamcord
POSTGRES_USER=teamcord
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# NATS
NATS_PORT=4222
NATS_MONITOR_PORT=8222

# Meilisearch
MEILI_MASTER_KEY=replace-with-meilisearch-master-key
MEILI_PORT=7700

# MinIO
MINIO_ROOT_USER=teamcord
MINIO_ROOT_PASSWORD=replace-with-strong-minio-password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=teamcord-files
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=teamcord
MINIO_SECRET_KEY=replace-with-strong-minio-password

# Keycloak
KEYCLOAK_ADMIN_PASSWORD=replace-with-strong-keycloak-admin-password
KEYCLOAK_PORT=8080
KEYCLOAK_REALM=teamcord
KEYCLOAK_ISSUER=http://localhost:8080/realms/teamcord
KEYCLOAK_INTERNAL_ISSUER=http://keycloak:8080/realms/teamcord
KEYCLOAK_CLIENT_ID=teamcord-web
KEYCLOAK_URL=http://localhost:8080

# Files Service
FILES_PUBLIC_URL=http://localhost:3003
FILES_SIGNED_URL_TTL_SECONDS=300
FILES_MAX_UPLOAD_MB=25

# Ollama
OLLAMA_PORT=11434

# AI Agent
ANTHROPIC_API_KEY= # Optional: For Plus/Pro tiers
OLLAMA_MODEL=llama3.1:8b

# Voice
ANNOUNCED_IP=127.0.0.1 # Replace with your public IP for production

# Security
JWT_SECRET=replace-with-strong-jwt-secret

# Domain & URLs
DOMAIN=localhost
API_URL=http://localhost:3001
GATEWAY_URL=ws://localhost:3002
WEB_PORT=3000
VITE_API_URL=http://localhost:3001
VITE_GATEWAY_URL=ws://localhost:3002
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=teamcord
VITE_KEYCLOAK_CLIENT_ID=teamcord-web
