# TeamCord — Environment Variables
# Copy this file to .env and fill in your values

# ─── Security (CHANGE THESE IN PRODUCTION) ───────────────────────────────────
JWT_SECRET=change-me-in-production-please-use-a-long-random-string

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=teamcord_secret
DATABASE_URL=postgres://teamcord:teamcord_secret@localhost:5432/teamcord

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MinIO (file storage) ────────────────────────────────────────────────────
MINIO_ROOT_USER=teamcord
MINIO_ROOT_PASSWORD=teamcord_secret

# ─── Ollama (AI agent) ────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
# Model to use — run: docker exec teamcord-ollama-1 ollama pull llama3
OLLAMA_MODEL=llama3

# ─── App URLs ────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
GATEWAY_URL=ws://localhost:3002
AGENT_URL=http://localhost:3003

# ─── Next.js public env vars ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_GATEWAY_URL=ws://localhost:3002
NEXT_PUBLIC_AGENT_URL=http://localhost:3003

# ─── Ports ───────────────────────────────────────────────────────────────────
WEB_PORT=3000
API_PORT=3001
GATEWAY_PORT=3002
AGENT_PORT=3003
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
OLLAMA_PORT=11434
