# TeamCord — Environment Variables
# Copy this file to .env and fill in your values

# ─── Domain (for production TLS) ───────────────────────────────────────────────
# Set this to your domain for auto-TLS with Caddy
DOMAIN=localhost

# ─── Security (CHANGE THESE IN PRODUCTION) ───────────────────────────────────
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
POSTGRES_PASSWORD=teamcord_secret
MINIO_ROOT_PASSWORD=teamcord_secret
MEILI_MASTER_KEY=teamcord_meili_key

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://teamcord:teamcord_secret@localhost:5432/teamcord

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── NATS JetStream ──────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ─── Meilisearch ─────────────────────────────────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=teamcord_meili_key
MEILI_ENV=development

# ─── MinIO (file storage) ────────────────────────────────────────────────────
MINIO_ROOT_USER=teamcord
MINIO_ENDPOINT=localhost
MINIO_BUCKET=teamcord-files

# ─── Ollama (AI agent) ────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
# Model to use — run: docker exec teamcord-ollama-1 ollama pull llama3.1:8b
OLLAMA_MODEL=llama3.1:8b

# ─── Anthropic (Plus/Pro tier AI) ─────────────────────────────────────────────
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Voice/Video (mediasoup) ──────────────────────────────────────────────────
# Your server's public IP (required for WebRTC)
ANNOUNCED_IP=
# WebRTC port range
RTC_MIN_PORT=10000
RTC_MAX_PORT=10100

# ─── App URLs ────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
GATEWAY_URL=ws://localhost:3002
AGENT_URL=http://localhost:3003
VOICE_URL=ws://localhost:3004

# ─── Next.js public env vars ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_GATEWAY_URL=ws://localhost:3002
NEXT_PUBLIC_AGENT_URL=http://localhost:3003
NEXT_PUBLIC_VOICE_URL=ws://localhost:3004

# ─── Ports ───────────────────────────────────────────────────────────────────
WEB_PORT=3000
API_PORT=3001
GATEWAY_PORT=3002
AGENT_PORT=3003
VOICE_PORT=3004
POSTGRES_PORT=5432
REDIS_PORT=6379
NATS_PORT=4222
NATS_MONITOR_PORT=8222
MEILI_PORT=7700
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
OLLAMA_PORT=11434
