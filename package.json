{
  "name": "teamcord",
  "version": "0.1.0",
  "private": true,
  "description": "TeamCord - Discord but for small teams and agencies",
  "keywords": ["communication", "team", "chat", "discord-alternative", "self-hosted"],
  "author": "TeamCord Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @teamcord/web dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:push": "pnpm --filter @teamcord/db db:push",
    "db:migrate": "pnpm --filter @teamcord/db db:migrate",
    "db:studio": "pnpm --filter @teamcord/db db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2",
    "@types/node": "^22.10.7"
  }
}
