{
  "name": "nexus",
  "version": "1.0.0",
  "private": true,
  "description": "Nexus - Team Communication Platform",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:web": "pnpm --filter @nexus/web dev",
    "dev:api": "pnpm --filter @nexus/api dev",
    "build": "pnpm --parallel -r build",
    "build:web": "pnpm --filter @nexus/web build",
    "build:api": "pnpm --filter @nexus/api build",
    "lint": "pnpm --parallel -r lint",
    "test": "pnpm --parallel -r test",
    "db:migrate": "pnpm --filter @nexus/api db:migrate",
    "db:generate": "pnpm --filter @nexus/api db:generate",
    "db:seed": "pnpm --filter @nexus/api db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "keywords": ["communication", "team", "chat", "discord-alternative"],
  "author": "Nexus Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
